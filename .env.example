# Breeze -- Environment Variables
# Copy this to .env and fill in your values: cp .env.example .env

# --- Anthropic (required) ---
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Slack (required) ---
# Create a Slack app at https://api.slack.com/apps
# Enable Socket Mode, add bot scopes, install to workspace
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# --- Microsoft 365 (required) ---
# Register an app at https://portal.azure.com > Azure AD > App registrations
# Add delegated permissions: Calendars.ReadWrite, Mail.Send, User.Read
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=

# --- Scheduling (optional) ---
# Timezone for scheduling (default: UTC)
BREEZE_TIMEZONE=America/New_York

# Morning digest time in 24h format (default: 08:30)
BREEZE_DIGEST_TIME=08:30

# How often to check for conflicts in minutes (default: 60)
BREEZE_CONFLICT_CHECK_INTERVAL=60
